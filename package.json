{
  "name": "promptmate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "npm run generate:validators",
    "dev": "vite",
    "generate:validators": "node scripts/generate-validators.mjs",
    "build": "npm run generate:validators && tsc -b && vite build",
    "preview": "vite preview",
    "pretest": "npm run generate:validators",
    "test": "vitest run",
    "pretest:watch": "npm run generate:validators",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"resources/**/*.json\" \"scripts/**/*.mjs\" \"*.{json,js,ts,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"resources/**/*.json\" \"scripts/**/*.mjs\" \"*.{json,js,ts,html}\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "ajv": "8.20.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "17.4.0",
    "jsdom": "28.1.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
